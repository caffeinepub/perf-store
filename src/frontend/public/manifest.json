      "url": "/?tab=partner",
      "icons": [
        {
          "src": "/assets/generated/pwa-icon-192.dim_192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Stores",
      "short_name": "Stores",
      "description": "Browse partner stores (Alt+S)",
      "url": "/?tab=stores",
      "icons": [
        {
          "src": "/assets/generated/pwa-icon-192.dim_192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "navigate-existing", "navigate-new"]
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"]
