      "icons": [
        {
          "src": "/assets/generated/pwa-icon-192.dim_192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "storage": {
    "estimate": true
